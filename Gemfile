source "https://rubygems.org"

# Built and deployed with Jekyll 4 via GitHub Actions (see .github/workflows/deploy.yml),
# so we are not limited to the github-pages gem's older Jekyll.
gem "jekyll", "~> 4.2"

# Ruby 3.0+ no longer ships webrick in the standard library; needed for `jekyll serve`.
gem "webrick", "~> 1.8"
